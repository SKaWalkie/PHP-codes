<?php
if($_SERVER["REQUEST_METHOD"]=="POST"){
    $rs = pg_query_params($conn, "select * from Route where source=$1", array($s));
    echo "<table border=1><tr><th>No</th><th>Source</th><th>Destination</th><th>Stations</th></tr>";
    while($row = pg_fetch_assoc($rs)){
        echo "<tr><td>{$row['route_no']}</td><td>{$row['source']}</td><td>{$row['destination']}</td><td>{$row['no_of_stations']}</td></tr>";
    }
    echo "</table>";
}
?>
